# PlayWebit Network — Node Environment Variables
# Copy this to .env and fill in your values
# Never commit .env to git

# ─────────────────────────────────────────────
# NODE IDENTITY (required)
# ─────────────────────────────────────────────

# Your node's wallet private key (MetaMask export)
NODE_WALLET_PRIVATE_KEY=your_node_wallet_private_key_here

# Your node's public URL (must be reachable by other nodes)
NODE_PUBLIC_URL=https://your-node-url.com

# Port to run on (default 7860 for HuggingFace)
NODE_PORT=7860

# ─────────────────────────────────────────────
# STORAGE — choose one
# ─────────────────────────────────────────────

# Supabase (HuggingFace nodes — no persistent disk)
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# SQLite (VPS/AWS — just set a path, no extra config)
# SQLITE_DB_PATH=./chain.db

# LevelDB (fastest — VPS/AWS)
# LEVELDB_PATH=./chaindata

# ─────────────────────────────────────────────
# PLATFORM (optional)
# ─────────────────────────────────────────────

# What platform/dApp is running on this node
PLATFORM_ID=unknown

# ─────────────────────────────────────────────
# LOGGING (optional)
# ─────────────────────────────────────────────

LOG_LEVEL=INFO
DEBUG=False

# ─────────────────────────────────────────────
# NOTE: These are hardcoded in playweb/config.py
# DO NOT set them here — they are intentionally
# not configurable by node operators.
# ─────────────────────────────────────────────
# PLAYWEBIT_AUTHORITY_WALLET  → hardcoded in config.py
# PLAYWEBIT_BOOTSTRAP_URL     → hardcoded in config.py
# CHAIN_ID                    → 4968 (hardcoded)
# TRANSACTION_FEE             → 1 PLWB (hardcoded)
# FEE_SPLIT                   → 50/50 (hardcoded)
